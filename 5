        end
        local data = game:GetService("HttpService"):JSONEncode({
            content = "Banana Cat Hub - Webhook test thanh cong!"
        })
        local ok, err = pcall(function()
            game:GetService("HttpService"):PostAsync(webhookURL, data)
        end)
        if ok then
            Fluent:Notify({ Title = "Webhook", Content = "Gui thanh cong!", Duration = 3 })
        else
            Fluent:Notify({ Title = "Webhook", Content = "Loi: " .. tostring(err), Duration = 3 })
        end
    end
})

