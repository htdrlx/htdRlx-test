-- Boss/event labels
local function makeLabel(title)
    return Tabs.StatsAndServer:AddParagraph({ Title = title, Content = "X" })
end

local eliteHunterLabel     = makeLabel("Elite Hunter")
local tyrantEyesLabel      = makeLabel("Tyrant Eyes")
local cakePrinceLabel      = makeLabel("Cake Prince")
local leviathanLabel       = makeLabel("Leviathan")
local mirageLabel          = makeLabel("Mirage Island")
local prehistoricLabel     = makeLabel("Prehistoric Island")
local frozenLabel          = makeLabel("Frozen Dimension")
local moonLabel            = makeLabel("Moon")
local ancientOneLabel      = makeLabel("Ancient One You Are")

-- Helper check value
local function checkVal(path)
    local ok, val = pcall(function()
        return game:GetService("ReplicatedStorage")[path].Value
    end)
    if not ok then return nil end
    return val
end

local startTime = tick()
local moonCount = 0
local moonMax = 5 -- full moon sau 5 dem

RunService.Heartbeat:Connect(function()
    -- Timer
    local clockTime = game:GetService("Lighting").ClockTime
    local h = math.floor(clockTime)
    local m = math.floor((clockTime - h) * 60)
    local s = math.floor(((clockTime - h) * 60 - m) * 60)
    timerLabel:Set("Timer", string.format("%02d h  %02d m  %02d s", h, m, s))

    -- Server Timer
    local elapsed = tick() - startTime
    local sh = math.floor(elapsed / 3600)
    local sm = math.floor((elapsed % 3600) / 60)
    local ss = math.floor(elapsed % 60)
    serverTimerLabel:Set("Server Timer", string.format("%02d h  %02d m  %02d s", sh, sm, ss))

    -- Fist timer placeholder
    fistTimerLabel:Set("Next Timer Spam Fist Of Darkness Or God's Chalice", "00 h  00 m  00 s")

    -- Boss/event check (dung X neu ko co, tick neu co)
    local function getStatus(path)
        local val = checkVal(path)
        if val == nil then return "X" end
        if val == true or val == 1 then return "V" end
        return "X"
    end

    eliteHunterLabel:Set("Elite Hunter",         getStatus("EliteHunter"))
    tyrantEyesLabel:Set("Tyrant Eyes",           getStatus("TyrantEyes"))
    cakePrinceLabel:Set("Cake Prince",           getStatus("CakePrince"))
    leviathanLabel:Set("Leviathan",              getStatus("Leviathan"))
    mirageLabel:Set("Mirage Island",             getStatus("MirageIsland"))
    prehistoricLabel:Set("Prehistoric Island",   getStatus("PrehistoricIsland"))
    frozenLabel:Set("Frozen Dimension",          getStatus("FrozenDimension"))
    ancientOneLabel:Set("Ancient One You Are",   getStatus("AncientOne"))

    -- Moon: hien thi x/5
    local moonVal = checkVal("MoonCount")
    if moonVal then
        moonCount = tonumber(moonVal) or moonCount
    end
    moonLabel:Set("Moon", moonCount .. " / " .. moonMax)
end)

