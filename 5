    end
})

Tabs.StatsAndServer:AddToggle("SpamJoin", {
    Title = "Spam Join",
    Description = "Spam join server theo JobID",
    Default = false
})

Options.SpamJoin:OnChanged(function()
    if Options.SpamJoin.Value then
        task.spawn(function()
            while Options.SpamJoin.Value do
                if jobIDInput ~= "" then
                    pcall(function()
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, jobIDInput, player)
                    end)
                end
                task.wait(1)
            end
        end)
    end
end)

Tabs.StatsAndServer:AddButton({
    Title = "Copy Join",
    Description = "Copy link join server",
    Callback = function()
        if jobIDInput ~= "" then
            setclipboard("roblox://experiences/start?placeId=" .. game.PlaceId .. "&gameInstanceId=" .. jobIDInput)
            Fluent:Notify({ Title = "Server", Content = "Da copy link!", Duration = 3 })
        else
            Fluent:Notify({ Title = "Server", Content = "Nhap JobID truoc!", Duration = 3 })
        end
    end
})

Tabs.StatsAndServer:AddButton({
    Title = "Rejoin Server",
    Description = "Rejoin server hien tai",
    Callback = function()
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    end
})

Tabs.StatsAndServer:AddButton({
    Title = "Hop Server",
    Description = "Nhay sang server ngau nhien",
    Callback = function()
        pcall(function()
            local servers = TeleportService:GetPlayerPlaceInstancesAsync(player.UserId)
            TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[1], player)
        end)
    end
})

Tabs.StatsAndServer:AddButton({
    Title = "Hop Server Less Player",
    Description = "Nhay sang server it nguoi nhat",
    Callback = function()
        local Http = game:GetService("HttpService")
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        local ok, res = pcall(function() return Http:GetAsync(url) end)
        if ok then
            local data = Http:JSONDecode(res)
            local best, bestCount = nil, math.huge
            for _, s in ipairs(data.data) do
                if s.playing < bestCount and s.id ~= game.JobId then
                    best = s.id
                    bestCount = s.playing
                end
            end
            if best then
                TeleportService:TeleportToPlaceInstance(game.PlaceId, best, player)
            end
        end
    end
})

