local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Window = Rayfield:CreateWindow({
    Name = "Fly & Aura",
    LoadingTitle = "Fly & Aura",
    LoadingSubtitle = "By Obii",
    Theme = "Default",
})

local Tab = Window:CreateTab("Main", 4483362458)
local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")

local flyConn, noclipConn, cacheConn
local cachedMob = nil
local cacheTimer = 0
local speedVal = 310

-- Cache mob gần nhất mỗi 0.5s, quét toàn bộ workspace
cacheConn = RunService.Heartbeat:Connect(function(dt)
    cacheTimer = cacheTimer + dt
    if cacheTimer < 0.5 then return end
    cacheTimer = 0
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then cachedMob = nil return end

    local nearest, nearDist = nil, math.huge
    -- Duyệt tất cả HumanoidRootPart trong workspace
    for _, part in ipairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") and part.Name == "HumanoidRootPart" then
            local model = part.Parent
            if model and model:IsA("Model") and model ~= char then
                local hum = model:FindFirstChildWhichIsA("Humanoid")
                if hum and hum.Health > 0 then
                    local d = (hrp.Position - part.Position).Magnitude
                    if d < nearDist then
                        nearest = part
                        nearDist = d
                    end
                end
            end
        end
    end
    cachedMob = nearest
end)

Tab:CreateSlider({
    Name = "Speed Tween",
    Range = {50, 500},
    Increment = 10,
    Suffix = "Speed",
    CurrentValue = 310,
    Flag = "SpeedTween",
    Callback = function(val)
        speedVal = val
    end
})

Tab:CreateToggle({
    Name = "Fly",
    CurrentValue = false,
    Flag = "FlyToggle",
    Callback = function(val)
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end

        if val then
            hum.PlatformStand = true

            local bf = Instance.new("BodyForce")
            bf.Name = "FlyBF"
            bf.Force = Vector3.new(0, workspace.Gravity * hrp.AssemblyMass, 0)
            bf.Parent = hrp

            local bv = Instance.new("BodyVelocity")
            bv.Name = "FlyBV"
            bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
            bv.Velocity = Vector3.zero
            bv.Parent = hrp

            noclipConn = RunService.Stepped:Connect(function()
                local c = player.Character
                if not c then return end
                for _, p in ipairs(c:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end)

            flyConn = RunService.Heartbeat:Connect(function()
                local h = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if not h then return end

                local bf2 = h:FindFirstChild("FlyBF")
                if bf2 then
                    bf2.Force = Vector3.new(0, workspace.Gravity * h.AssemblyMass, 0)
                end

                local bv2 = h:FindFirstChild("FlyBV")
                if not bv2 then return end

                local target = cachedMob
                if not target then
                    bv2.Velocity = Vector3.zero
                    return
                end

                local targetPos = Vector3.new(
                    target.Position.X,
                    target.Position.Y + 30,
                    target.Position.Z
                )
                local dir = targetPos - h.Position
                if dir.Magnitude > 3 then
                    bv2.Velocity = dir.Unit * speedVal
                else
                    bv2.Velocity = Vector3.zero
                end
            end)
        else
            if flyConn then flyConn:Disconnect() end
            if noclipConn then noclipConn:Disconnect() end
            if hrp:FindFirstChild("FlyBV") then hrp.FlyBV:Destroy() end
            if hrp:FindFirstChild("FlyBF") then hrp.FlyBF:Destroy() end
            hum.PlatformStand = false
            local c = player.Character
            if c then
                for _, p in ipairs(c:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = true end
                end
            end
        end
    end
})

Rayfield:Notify({
    Title = "Fly & Aura",
    Content = "Đã load thành công!",
    Duration = 3,
    Image = 4483362458,
})
