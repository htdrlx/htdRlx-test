local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Window = Rayfield:CreateWindow({
    Name = "Fly & Aura",
    LoadingTitle = "Fly & Aura",
    LoadingSubtitle = "By Obii",
    Theme = "Default",
})

local Tab = Window:CreateTab("Main", 4483362458)
local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")

local flyConn, noclipConn, cacheConn
local cachedMob = nil
local cacheTimer = 0
local speedVal = 310

-- Cache mob mỗi 0.5s
cacheConn = RunService.Heartbeat:Connect(function(dt)
    cacheTimer = cacheTimer + dt
    if cacheTimer < 0.5 then return end
    cacheTimer = 0
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then cachedMob = nil return end
    local nearest, nearDist = nil, math.huge
    for _, v in ipairs(workspace:GetChildren()) do
        if v:IsA("Model") and v ~= char
            and v:FindFirstChildWhichIsA("Humanoid")
            and v:FindFirstChild("HumanoidRootPart")
            and v:FindFirstChildWhichIsA("Humanoid").Health > 0 then
            local d = (hrp.Position - v.HumanoidRootPart.Position).Magnitude
            if d < nearDist then
                nearest = v.HumanoidRootPart
                nearDist = d
            end
        end
    end
    cachedMob = nearest
end)

Tab:CreateSlider({
    Name = "Speed Tween",
    Range = {50, 500},
    Increment = 10,
    Suffix = "Speed",
    CurrentValue = 310,
    Flag = "SpeedTween",
    Callback = function(val)
        speedVal = val
    end
})

Tab:CreateToggle({
    Name = "Fly",
    CurrentValue = false,
    Flag = "FlyToggle",
    Callback = function(val)
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end

        if val then
            -- Tắt physics humanoid
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
            hum:ChangeState(Enum.HumanoidStateType.Physics)

            -- Noclip
            noclipConn = RunService.Stepped:Connect(function()
                local c = player.Character
                if not c then return end
                for _, p in ipairs(c:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end)

            -- BodyVelocity MaxForce vô hạn
            local bv = Instance.new("BodyVelocity")
            bv.Name = "FlyBV"
            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bv.Velocity = Vector3.zero
            bv.Parent = hrp

            flyConn = RunService.Heartbeat:Connect(function()
                local h = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if not h or not h:FindFirstChild("FlyBV") then return end
                local target = cachedMob
                if not target then
                    h.FlyBV.Velocity = Vector3.zero
                    return
                end
                local targetPos = Vector3.new(
                    target.Position.X,
                    target.Position.Y + 30,
                    target.Position.Z
                )
                local dir = targetPos - h.Position
                if dir.Magnitude > 3 then
                    h.FlyBV.Velocity = dir.Unit * speedVal
                else
                    h.FlyBV.Velocity = Vector3.zero
                end
            end)
        else
            if flyConn then flyConn:Disconnect() end
            if noclipConn then noclipConn:Disconnect() end
            if hrp:FindFirstChild("FlyBV") then hrp.FlyBV:Destroy() end
            -- Bật lại physics
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            local c = player.Character
            if c then
                for _, p in ipairs(c:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = true end
                end
            end
        end
    end
})

Rayfield:Notify({
    Title = "Fly & Aura",
    Content = "Đã load thành công!",
    Duration = 3,
    Image = 4483362458,
})
