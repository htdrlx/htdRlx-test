-- ================== 3. HELPER: KIỂM TRA MỤC TIÊU CÒN SỐNG ==================
local function isTargetAlive(model)
    if not model or not model.Parent then return false end
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    local hrp = model:FindFirstChild("HumanoidRootPart")
    return humanoid ~= nil and hrp ~= nil and humanoid.Health > 0
end

-- ================== 4. TÌM KẺ ĐỊCH GẦN NHẤT ==================
local function getNearestEnemy()
    local character = player.Character
    if not character then return nil end
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local nearest = nil
    local minDist = math.huge

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= character then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if humanoid and hrp and humanoid.Health > 0 then
                local dist = (root.Position - hrp.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = obj
                end
            end
        end
    end
    return nearest
end

-- ================== 5. TÌM NPC NHẬN NHIỆM VỤ GẦN NHẤT ==================
-- NPC quest thường không có Humanoid hoặc Health = 0 và tên chứa từ khóa quest
local QUEST_KEYWORDS = {"quest", "npc", "mission", "task", "giver", "give", "accept", "merchant", "villager", "elder", "chief"}

local function isQuestNPC(model)
    if not model or model == player.Character then return false end
    local name = model.Name:lower()
    for _, kw in ipairs(QUEST_KEYWORDS) do
        if name:find(kw) then return true end
    end
    -- Cũng check NPC không có humanoid (NPC tĩnh)
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        -- Có HumanoidRootPart nhưng không có Humanoid → NPC tĩnh
        local hrp = model:FindFirstChild("HumanoidRootPart")
        if hrp then return true end
    end
    return false
end

local function getNearestQuestNPC()
    local character = player.Character
    if not character then return nil end
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local nearest = nil
    local minDist = math.huge

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and isQuestNPC(obj) then
            local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("PrimaryPart")
            if hrp then
                local dist = (root.Position - hrp.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = obj
                end
            end
        end
    end
    return nearest
end

-- ================== 6. BAY ĐẾN MỤC TIÊU (ĐỘ CAO 25) ==================
local function flyTo(charHRP, targetCFrame)
    local cam = workspace.CurrentCamera
    cam.CameraType = Enum.CameraType.Scriptable

    -- Lấy vị trí đích với độ cao FLY_HEIGHT so với đất
    local targetPos = targetCFrame.Position
    local highPos = Vector3.new(targetPos.X, targetPos.Y + FLY_HEIGHT, targetPos.Z)

    -- Lấy hướng nhìn từ char sang target (giữ nguyên trục Y)
    local lookAt = Vector3.new(targetPos.X, highPos.Y, targetPos.Z)
    local flyCFrame = CFrame.lookAt(highPos, lookAt) * CFrame.new(0, 0, ATTACK_RANGE)

    local distance = (charHRP.Position - flyCFrame.Position).Magnitude
    local tweenTime = math.clamp(distance / TWEEN_SPEED, 0.05, 2)

    local tween = TweenService:Create(charHRP, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {CFrame = flyCFrame})
    tween:Play()
    tween.Completed:Wait()

    -- Trả camera về ngay sau khi bay xong
    cam.CameraType = Enum.CameraType.Custom
    RunService.RenderStepped:Wait()
end

-- ================== 7. TƯƠNG TÁC NPC (NHẬN NHIỆM VỤ) ==================
local function interactNPC()
    -- Thử các key thông dụng để nhận quest: E, F, Space
    for _, key in ipairs({Enum.KeyCode.E, Enum.KeyCode.F}) do
        VirtualInputManager:SendKeyEvent(true, key, false, game)
        task.wait(0.1)
        VirtualInputManager:SendKeyEvent(false, key, false, game)
        task.wait(0.1)
    end
    -- Click chuột vào tâm màn hình
    local cam = workspace.CurrentCamera
    local screenSize = cam.ViewportSize
    local cx = math.floor(screenSize.X / 2)
    local cy = math.floor(screenSize.Y / 2)
    VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
end

-- ================== 8. AUTO FARM LOOP ==================
local function autoFarmLoop()
    while autoFarm do
        local character = player.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if not (character and humanoid and humanoid.Health > 0) then
            task.wait(0.5)
            continue
        end

        local charHRP = character:FindFirstChild("HumanoidRootPart")
        if not charHRP then task.wait(0.5) continue end

        -- ================== LOGIC KHÓA MỤC TIÊU ==================
        -- Chỉ đổi mục tiêu nếu:
        -- 1. Chưa có mục tiêu
        -- 2. Mục tiêu hiện tại đã chết
        if not isTargetAlive(currentTarget) then
            currentTarget = nil
            -- Thử tìm NPC quest trước
            local questNPC = getNearestQuestNPC()
            if questNPC then
                local npcHRP = questNPC:FindFirstChild("HumanoidRootPart") or questNPC.PrimaryPart
                if npcHRP then
                    flyTo(charHRP, npcHRP.CFrame)
                    interactNPC()
                    task.wait(1) -- Chờ UI quest hiện
                end
            else
                -- Không có NPC quest thì tìm kẻ địch
                currentTarget = getNearestEnemy()
            end
        end

        -- Tấn công mục tiêu đang bị khóa
        if isTargetAlive(currentTarget) then
            local targetHRP = currentTarget:FindFirstChild("HumanoidRootPart")
            if targetHRP then
                local distance = (charHRP.Position - targetHRP.Position).Magnitude

                -- Bay đến nếu còn xa
                if distance > ATTACK_RANGE + 1 then
                    flyTo(charHRP, targetHRP.CFrame)
                end

                -- Kiểm tra lại sau khi bay xong (target có thể chết trong lúc bay)
                if isTargetAlive(currentTarget) then
                    local cam = workspace.CurrentCamera
                    local screenSize = cam.ViewportSize
                    local cx = math.floor(screenSize.X / 2)
                    local cy = math.floor(screenSize.Y / 2)

                    VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
                    task.wait(0.05)
                    VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
                else
                    -- Target chết trong lúc bay → reset để vòng sau chọn target mới
                    currentTarget = nil
                end
            end
        end

        task.wait(0.3)
    end

    -- Reset khi tắt farm
    currentTarget = nil
    local cam = workspace.CurrentCamera
    if cam then cam.CameraType = Enum.CameraType.Custom end
end

