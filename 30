local ToggleAuto = Tabs.Main:AddToggle("ToggleAuto", {
    Title = "Auto Farm Level",
    Description = "Bay độ cao 25, khóa mục tiêu, nhận quest NPC",
    Default = false
})

ToggleAuto:OnChanged(function()
    autoFarm = Options.ToggleAuto.Value
    if autoFarm then
        if autoFarmThread then
            task.cancel(autoFarmThread)
            autoFarmThread = nil
        end
        currentTarget = nil
        autoFarmThread = task.spawn(autoFarmLoop)
    else
        if autoFarmThread then
            task.cancel(autoFarmThread)
            autoFarmThread = nil
        end
        currentTarget = nil
        local cam = workspace.CurrentCamera
        if cam then cam.CameraType = Enum.CameraType.Custom end
    end
end)

