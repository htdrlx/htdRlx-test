RunService.Heartbeat:Connect(function()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, v in ipairs(workspace:GetChildren()) do
        if v:IsA("Model") and v ~= char then
            local hum = v:FindFirstChild("Humanoid")
            local mobHRP = v:FindFirstChild("HumanoidRootPart")
            if hum and mobHRP and hum.Health > 0 then
                local dist = (hrp.Position - mobHRP.Position).Magnitude
                local hp = (hum.Health / hum.MaxHealth) * 100
                if dist <= 60 and hp <= Options.KillAtHeart.Value then
                    pcall(function()
                        local VIM = game:GetService("VirtualInputManager")
                        VIM:SendKeyEvent(true, Options.SkillMelee.Value or "Z", false, game)
                        task.wait(Options.HoldSkillZ.Value)
                        VIM:SendKeyEvent(false, Options.SkillMelee.Value or "Z", false, game)
                        task.wait(0.1)
                        VIM:SendKeyEvent(true, "X", false, game)
                        task.wait(Options.HoldSkillX.Value)
                        VIM:SendKeyEvent(false, "X", false, game)
                        task.wait(0.1)
                        VIM:SendKeyEvent(true, "C", false, game)
                        task.wait(Options.HoldSkillC.Value)
                        VIM:SendKeyEvent(false, "C", false, game)
                    end)
                end
            end
        end
    end
end)

