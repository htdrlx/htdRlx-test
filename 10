local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "Fly & Aura",
    SubTitle = "By Obii",
    TabWidth = 160,
    Size = UDim2.fromOffset(400, 320),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.RightControl
})

local Tab = Window:AddTab({ Title = "Main", Icon = "zap" })
local Options = Fluent.Options
local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")

local flyConn, auraConn, noclipConn, cacheConn
local cachedMob = nil

-- Cache mob mỗi 0.5s
local cacheTimer = 0
cacheConn = RunService.Heartbeat:Connect(function(dt)
    cacheTimer = cacheTimer + dt
    if cacheTimer < 0.5 then return end
    cacheTimer = 0
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then cachedMob = nil return end
    local nearest, dist = nil, math.huge
    for _, v in ipairs(workspace:GetChildren()) do
        if v:IsA("Model") and v ~= char
            and v:FindFirstChild("Humanoid")
            and v:FindFirstChild("HumanoidRootPart")
            and v.Humanoid.Health > 0 then
            local d = (hrp.Position - v.HumanoidRootPart.Position).Magnitude
            if d < dist then
                nearest = v.HumanoidRootPart
                dist = d
            end
        end
    end
    cachedMob = nearest
end)

-- ========================
-- SPEED TWEEN
-- ========================

Tab:AddSlider("SpeedTween", {
    Title = "Speed Tween",
    Description = "Tốc độ bay đến quái (mặc định 310)",
    Default = 310,
    Min = 50,
    Max = 500,
    Rounding = 0,
})

-- ========================
-- FLY
-- ========================

Tab:AddToggle("FlySmooth", {
    Title = "Fly",
    Description = "Bay mượt trên quái 30 studs, cam đuổi theo sau bình thường",
    Default = false
})

Options.FlySmooth:OnChanged(function()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if Options.FlySmooth.Value then
        -- Cam mặc định, không chạm vào
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom

        -- Noclip
        noclipConn = RunService.Stepped:Connect(function()
            local c = player.Character
            if not c then return end
            for _, p in ipairs(c:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.CanCollide = false
                end
            end
        end)

        -- Dùng CFrame lerp mượt, không dùng BodyMover
        flyConn = RunService.Heartbeat:Connect(function(dt)
            local c = player.Character
            local h = c and c:FindFirstChild("HumanoidRootPart")
            if not h then return end

            local target = cachedMob
            if target then
                local targetPos = Vector3.new(
                    target.Position.X,
                    target.Position.Y + 30,
                    target.Position.Z
                )
                -- Lerp mượt đến vị trí trên quái
                local speed = Options.SpeedTween.Value
                local alpha = math.clamp(speed * dt / 100, 0, 1)
                local newPos = h.Position:Lerp(targetPos, alpha)
                h.CFrame = CFrame.new(newPos) * (h.CFrame - h.CFrame.Position)
            end
        end)
    else
        if flyConn then flyConn:Disconnect() end
        if noclipConn then noclipConn:Disconnect() end
        local c = player.Character
        if c then
            for _, p in ipairs(c:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = true end
            end
        end
    end
end)

-- ========================
-- ATTACK AURA
-- ========================

Tab:AddSlider("AuraRadius", {
    Title = "Aura Radius",
    Description = "Bán kính tấn công aura",
    Default = 40,
    Min = 5,
    Max = 60,
    Rounding = 0,
})

Tab:AddToggle("AttackAura", {
    Title = "Attack Aura",
    Description = "Tự động đánh võ quái trong phạm vi",
    Default = false
})

Options.AttackAura:OnChanged(function()
    if Options.AttackAura.Value then
        auraConn = RunService.Heartbeat:Connect(function()
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            local target = cachedMob
            if target then
                local dist = (hrp.Position - target.Position).Magnitude
                if dist <= Options.AuraRadius.Value then
                    hrp.CFrame = CFrame.new(
                        hrp.Position,
                        Vector3.new(target.Position.X, hrp.Position.Y, target.Position.Z)
                    )
                    VIM:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                    task.wait(0.1)
                    VIM:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                end
            end
        end)
    else
        if auraConn then auraConn:Disconnect() end
    end
end)

Window:SelectTab(1)

Fluent:Notify({
    Title = "Fly & Aura",
    Content = "Đã load thành công!",
    Duration = 3
})
