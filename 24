local function autoFarmBoss(bossName, toggleKey)
    task.spawn(function()
        while Options[toggleKey] and Options[toggleKey].Value do
            local char = player.Character local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then for _, v in ipairs(workspace:GetChildren()) do if v.Name:find(bossName) and v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then hrp.CFrame = CFrame.new(v.HumanoidRootPart.Position + Vector3.new(0,30,0)) pcall(function() RS.Remotes.Combat:FireServer("M1", v) end) break end end end
            task.wait(0.5)
        end
    end)
end

local function hopFindBoss(bossName, toggleKey, notifText)
    task.spawn(function()
        while Options[toggleKey] and Options[toggleKey].Value do
            local found = false for _, v in ipairs(workspace:GetChildren()) do if v.Name:find(bossName) and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then found = true break end end
            if found then Fluent:Notify({ Title = "Stack Framing", Content = notifText, Duration = 3 }) Options[toggleKey]:SetValue(false) else hopServer() end
            task.wait(3)
        end
    end)
end

