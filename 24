local function checkVal(path)
    local ok, val = pcall(function() return RS[path].Value end)
    if not ok then return nil end
    return val
end

local startTime = tick()
local moonCount = 0
local FIST_INTERVAL = 4 * 3600

RunService.Heartbeat:Connect(function()
    local clockTime = game:GetService("Lighting").ClockTime
    local h = math.floor(clockTime)
    local m = math.floor((clockTime - h) * 60)
    local s = math.floor(((clockTime - h) * 60 - m) * 60)
    timerLabel:Set("Timer", string.format("%02d h  %02d m  %02d s", h, m, s))
    local elapsed = tick() - startTime
    serverTimerLabel:Set("Server Timer", string.format("%02d h  %02d m  %02d s", math.floor(elapsed/3600), math.floor((elapsed%3600)/60), math.floor(elapsed%60)))
    local timeLeft = FIST_INTERVAL - (os.time() % FIST_INTERVAL)
    fistTimerLabel:Set("Next Timer Spam Fist Of Darkness Or God's Chalice", string.format("%02d h  %02d m  %02d s", math.floor(timeLeft/3600), math.floor((timeLeft%3600)/60), math.floor(timeLeft%60)))
    local function getStatus(path) local val = checkVal(path) if val == nil then return "X" end if val == true or val == 1 then return "V" end return "X" end
    eliteHunterLabel:Set("Elite Hunter", getStatus("EliteHunter"))
    tyrantEyesLabel:Set("Tyrant Eyes", getStatus("TyrantEyes"))
    cakePrinceLabel:Set("Cake Prince", getStatus("CakePrince"))
    leviathanLabel:Set("Leviathan", getStatus("Leviathan"))
    mirageLabel:Set("Mirage Island", getStatus("MirageIsland"))
    prehistoricLabel:Set("Prehistoric Island", getStatus("PrehistoricIsland"))
    frozenLabel:Set("Frozen Dimension", getStatus("FrozenDimension"))
    ancientOneLabel:Set("Ancient One You Are", getStatus("AncientOne"))
    local moonVal = checkVal("MoonCount")
    if moonVal then moonCount = tonumber(moonVal) or moonCount end
    moonLabel:Set("Moon", moonCount .. " / 5")
end)

