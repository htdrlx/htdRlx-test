Options.FarmObservationHop:OnChanged(function() if Options.FarmObservationHop.Value then task.spawn(function() while Options.FarmObservationHop.Value do local found = false for _, v in ipairs(workspace:GetChildren()) do if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then found = true break end end if found then Fluent:Notify({ Title = "Framing Other", Content = "Đã tìm server có mob!", Duration = 3 }) Options.FarmObservationHop:SetValue(false) else hopServer() end task.wait(3) end end) end end)

Tabs.FramingOther:AddParagraph({ Title = "Auto Boss", Content = "Tự động farm Boss" })
local bossList = { "All","Blox Fruit Dealer Cousin","Bobby","Yeti","Snowman","Swan","Jeremy","Greybeard","Saber Expert","Magma Admiral","Fishman Lord","Wysper","Thunder God","Smoke Admiral","Cursed Captain","Darkbeard","Rip_Indra","Cake Prince","Dough King","Soul Reaper","Mammoths","Island Empress","Leviathan","Stone","Kilo Admiral","Captain Elephant","Beautiful Pirate","Longma","Tide Keeper","Wandering Pirate","Diamond","Don Swan","Bartolomeo","Kaido" }
Tabs.FramingOther:AddDropdown("SelectBoss", { Title = "Select Boss", Description = "Chọn boss muốn farm", Values = bossList, Multi = false, Default = 1 })
Tabs.FramingOther:AddToggle("KillBoss", { Title = "Kill Boss", Description = "Tự động farm boss đã chọn", Default = false })
Options.KillBoss:OnChanged(function() if Options.KillBoss.Value then task.spawn(function() while Options.KillBoss.Value do local char = player.Character local hrp = char and char:FindFirstChild("HumanoidRootPart") if hrp then local bossName = Options.SelectBoss.Value or "All" for _, v in ipairs(workspace:GetChildren()) do if v:IsA("Model") and v ~= char then local hum = v:FindFirstChild("Humanoid") local mobHRP = v:FindFirstChild("HumanoidRootPart") if hum and mobHRP and hum.Health > 0 then local nameMatch = bossName == "All" or v.Name:find(bossName) if nameMatch then hrp.CFrame = CFrame.new(mobHRP.Position + Vector3.new(0,30,0)) pcall(function() RS.Remotes.Combat:FireServer("M1", v) end) break end end end end end task.wait(0.5) end end) end end)
Tabs.FramingOther:AddToggle("KillAllBoss", { Title = "Kill All Boss", Description = "Tự động farm tất cả boss cùng lúc", Default = false })
Options.KillAllBoss:OnChanged(function() if Options.KillAllBoss.Value then task.spawn(function() while Options.KillAllBoss.Value do local char = player.Character local hrp = char and char:FindFirstChild("HumanoidRootPart") if hrp then for _, v in ipairs(workspace:GetChildren()) do if v:IsA("Model") and v ~= char then local hum = v:FindFirstChild("Humanoid") local mobHRP = v:FindFirstChild("HumanoidRootPart") if hum and mobHRP and hum.Health > 0 then hrp.CFrame = CFrame.new(mobHRP.Position + Vector3.new(0,30,0)) pcall(function() RS.Remotes.Combat:FireServer("M1", v) end) task.wait(0.3) end end end end task.wait(0.5) end end) end end)

