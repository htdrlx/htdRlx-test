-- ================== ĐỌC LEVEL TỪ GUI ==================
local function getPlayerLevel()
    -- Thử leaderstats trước
    local ls = player:FindFirstChild("leaderstats")
    if ls then
        for _, v in ipairs(ls:GetChildren()) do
            if v:IsA("IntValue") or v:IsA("NumberValue") then
                local n = v.Name:lower()
                if n:find("level") or n:find("lv") or n:find("cấp") or n:find("cap") then
                    return v.Value
                end
            end
        end
    end
    -- Tìm trong PlayerGui TextLabel
    local gui = player:FindFirstChild("PlayerGui")
    if gui then
        for _, obj in ipairs(gui:GetDescendants()) do
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                local txt = obj.Text or ""
                -- "Cấp 3", "Level 3", "Lv.3", "LV 3"
                local num = txt:match("[Cc][ấa]p%s*(%d+)")
                    or txt:match("[Ll][Ee][Vv][Ee][Ll]%s*(%d+)")
                    or txt:match("[Ll][Vv]%.?%s*(%d+)")
                if num then return tonumber(num) end
            end
        end
    end
    return 1
end

-- ================== AUTO DETECT ZONE ==================
-- Gom kẻ địch thành cluster theo vị trí
local function getEnemyClusters()
    local clusters = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= player.Character then
            local h = obj:FindFirstChildOfClass("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if h and hrp and h.Health > 0 then
                local pos = hrp.Position
                local added = false
                for _, c in ipairs(clusters) do
                    if (c.center - pos).Magnitude < CLUSTER_RADIUS then
                        -- Cập nhật center của cluster
                        c.count = c.count + 1
                        c.center = (c.center * (c.count - 1) + pos) / c.count
                        added = true; break
                    end
                end
                if not added then
                    table.insert(clusters, { center = pos, count = 1 })
                end
            end
        end
    end
    -- Sắp theo số lượng kẻ địch (cluster đông nhất trước)
    table.sort(clusters, function(a, b) return a.count > b.count end)
    return clusters
end

-- Chọn zone phù hợp với level (zone đông quái gần nhất)
local function getBestZone()
    local char = player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local clusters = getEnemyClusters()
    if #clusters == 0 then return nil end

    -- Ưu tiên cluster đông nhất trong tầm 500 studs
    -- Nếu không có thì lấy cluster gần nhất
    local best = nil
    local bestScore = -math.huge
    for _, c in ipairs(clusters) do
        local dist = (root.Position - c.center).Magnitude
        -- Score = số quái / khoảng cách (càng đông càng gần càng tốt)
        local score = c.count / math.max(dist, 1)
        if score > bestScore then bestScore = score; best = c end
    end
    return best
end

-- ================== TÌM NPC QUEST TRONG ZONE ==================
local QUEST_KW = {"quest", "npc", "mission", "give", "merchant", "elder", "chief", "nhiệm", "nhiem"}
local function findQuestNPCNearZone(zoneCenter)
    local nearest, minDist = nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= player.Character then
            local name = obj.Name:lower()
            local isQuest = false
            for _, kw in ipairs(QUEST_KW) do
                if name:find(kw) then isQuest = true; break end
            end
            -- NPC không có humanoid hoặc health = 0
            if not isQuest then
                local h = obj:FindFirstChildOfClass("Humanoid")
                if h and h.MaxHealth > 0 and h.Health >= h.MaxHealth then
                    isQuest = true -- NPC máu full không giảm
                end
            end
            if isQuest then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
                if hrp then
                    local dist = (zoneCenter - hrp.Position).Magnitude
                    if dist < 200 and dist < minDist then
                        minDist = dist; nearest = obj
                    end
                end
            end
        end
    end
    return nearest
end

-- ================== HELPER ==================
local function isTargetAlive(model)
    if not model or not model.Parent then return false end
    local h = model:FindFirstChildOfClass("Humanoid")
    return h ~= nil and h.Health > 0
end

local function getNearestEnemyInZone(zoneCenter)
    local char = player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local nearest, minDist = nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= char then
            local h = obj:FindFirstChildOfClass("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if h and hrp and h.Health > 0 then
                local distToZone = (zoneCenter - hrp.Position).Magnitude
                if distToZone < CLUSTER_RADIUS then
                    local d = (root.Position - hrp.Position).Magnitude
                    if d < minDist then minDist = d; nearest = obj end
                end
            end
        end
    end
    return nearest
end

-- ================== HOVER ==================
local function stopHover()
    if hoverConn then hoverConn:Disconnect(); hoverConn = nil end
    local char = player.Character
    local h = char and char:FindFirstChildOfClass("Humanoid")
    if h then h:ChangeState(Enum.HumanoidStateType.GettingUp) end
    local cam = workspace.CurrentCamera
    if cam then cam.CameraType = Enum.CameraType.Custom end
end

local function startHover()
    stopHover()
    local char = player.Character
    if not char then return end
    local charHRP = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not charHRP or not humanoid then return end
    humanoid:ChangeState(Enum.HumanoidStateType.Physics)

    hoverConn = RunService.Heartbeat:Connect(function()
        if not autoFarm or not isTargetAlive(currentTarget) then stopHover(); return end
        local char2 = player.Character
        local hrp2 = char2 and char2:FindFirstChild("HumanoidRootPart")
        local tHRP = currentTarget and currentTarget:FindFirstChild("HumanoidRootPart")
        if not hrp2 or not tHRP then stopHover(); return end
        local hoverY = tHRP.Position.Y + FLY_HEIGHT
        local dir = Vector3.new(hrp2.Position.X - tHRP.Position.X, 0, hrp2.Position.Z - tHRP.Position.Z)
        local offset = dir.Magnitude > 0 and dir.Unit * ATTACK_RANGE or Vector3.new(0,0,ATTACK_RANGE)
        hrp2.CFrame = CFrame.new(
            Vector3.new(tHRP.Position.X + offset.X, hoverY, tHRP.Position.Z + offset.Z),
            Vector3.new(tHRP.Position.X, hoverY, tHRP.Position.Z)
        )
    end)
end

-- ================== BAY (CAM GIẬT THEO NHÂN VẬT) ==================
local function flyTo(charHRP, targetPos)
    local char = player.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    humanoid:ChangeState(Enum.HumanoidStateType.Physics)

    local cam = workspace.CurrentCamera
    cam.CameraType = Enum.CameraType.Scriptable

    local highPos = Vector3.new(targetPos.X, targetPos.Y + FLY_HEIGHT, targetPos.Z)
    local dir = Vector3.new(charHRP.Position.X - targetPos.X, 0, charHRP.Position.Z - targetPos.Z)
    local offset = dir.Magnitude > 0 and dir.Unit * ATTACK_RANGE or Vector3.new(0,0,ATTACK_RANGE)
    local goalPos = highPos + offset
    local goalCF = CFrame.new(goalPos, Vector3.new(targetPos.X, goalPos.Y, targetPos.Z))

    -- Camera offset so với nhân vật (giữ khoảng cách cố định)
    local camOffset = cam.CFrame.Position - charHRP.Position

    local startCF = charHRP.CFrame
    local distance = (charHRP.Position - goalPos).Magnitude
    local totalTime = math.clamp(distance / TWEEN_SPEED, 0.05, 3)
    local elapsed = 0
    local done = false

    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not autoFarm then done = true; conn:Disconnect(); return end
        elapsed = elapsed + dt
        local alpha = math.clamp(elapsed / totalTime, 0, 1)

        -- Giật theo bước 0.05 (premium snap)
        local snapped = math.floor(alpha / 0.05) * 0.05
        local newCF = startCF:Lerp(goalCF, snapped)
        charHRP.CFrame = newCF

        -- Cam giật theo nhân vật (tách cam nhưng vẫn follow với offset cố định)
        cam.CFrame = CFrame.new(newCF.Position + camOffset, newCF.Position)

        if alpha >= 1 then done = true; conn:Disconnect() end
    end)

    while not done do RunService.Heartbeat:Wait() end
    cam.CameraType = Enum.CameraType.Custom
    task.wait(0.05)
end

-- ================== ATTACK (TÌM NÚT GUI) ==================
local attackButton = nil
local function findAttackButton()
    local gui = player:FindFirstChild("PlayerGui")
    if not gui then return nil end
    -- Tìm ImageButton ở phần dưới màn hình (Y > 60% viewport)
    local sz = workspace.CurrentCamera.ViewportSize
    local candidates = {}
    for _, obj in ipairs(gui:GetDescendants()) do
        if obj:IsA("ImageButton") and obj.Visible then
            local ok2, absp = pcall(function() return obj.AbsolutePosition end)
            if ok2 and absp.Y > sz.Y * 0.6 then
                local name = obj.Name:lower()
                -- Ưu tiên tên liên quan attack
                local priority = 0
                if name:find("attack") or name:find("punch") or name:find("hit") or name:find("fight") then priority = 2
                elseif name:find("skill") or name:find("basic") or name:find("normal") or name:find("action") then priority = 1
                end
                table.insert(candidates, {btn = obj, priority = priority, y = absp.Y})
            end
        end
    end
    -- Sắp: ưu tiên tên rõ ràng trước, sau đó lấy nút dưới cùng giữa màn hình
    table.sort(candidates, function(a, b)
        if a.priority ~= b.priority then return a.priority > b.priority end
        return a.y > b.y
    end)
    return candidates[1] and candidates[1].btn or nil
end

local function doAttack()
    if not attackButton or not attackButton.Parent then
        attackButton = findAttackButton()
    end
    if attackButton and attackButton.Parent then
        -- Fire event thẳng vào nút, không cần chuột
        pcall(function()
            local vFrame = attackButton.AbsolutePosition
            local vSize = attackButton.AbsoluteSize
            local cx = vFrame.X + vSize.X / 2
            local cy = vFrame.Y + vSize.Y / 2
            VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
        end)
    else
        -- Fallback: click giữa dưới màn hình
        local sz = workspace.CurrentCamera.ViewportSize
        VirtualInputManager:SendMouseButtonEvent(sz.X/2, sz.Y * 0.85, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(sz.X/2, sz.Y * 0.85, 0, false, game, 1)
    end
end

-- ================== NHẬN QUEST ==================
local function interactNPC(npc)
    local hrp = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
    if not hrp then return end
    local char = player.Character
    if not char then return end
    local charHRP = char:FindFirstChild("HumanoidRootPart")
    if charHRP then
        flyTo(charHRP, hrp.Position)
    end
    -- Thử các phím nhận quest phổ biến
    for _, key in ipairs({Enum.KeyCode.F, Enum.KeyCode.E}) do
        VirtualInputManager:SendKeyEvent(true, key, false, game)
        task.wait(0.15)
        VirtualInputManager:SendKeyEvent(false, key, false, game)
    end
    -- Click vào NPC
    local sz = workspace.CurrentCamera.ViewportSize
    VirtualInputManager:SendMouseButtonEvent(sz.X/2, sz.Y/2, 0, true, game, 1)
    task.wait(0.1)
    VirtualInputManager:SendMouseButtonEvent(sz.X/2, sz.Y/2, 0, false, game, 1)
    task.wait(1.5) -- chờ quest UI hiện
end

-- ================== MAIN LOOP ==================
local questDoneForZone = {} -- tránh nhận quest lại

local function autoFarmLoop()
    while autoFarm do
        local char = player.Character
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        if not (char and humanoid and humanoid.Health > 0) then
            stopHover(); task.wait(0.5); continue
        end
        local charHRP = char:FindFirstChild("HumanoidRootPart")
        if not charHRP then task.wait(0.5); continue end

        -- ===== BƯỚC 1: Tìm zone tốt nhất theo level =====
        if not currentZone then
            currentZone = getBestZone()
            if currentZone then
                local zKey = tostring(math.floor(currentZone.center.X)) .. "_" .. tostring(math.floor(currentZone.center.Z))
                -- ===== BƯỚC 2: Nhận quest NPC trong zone (1 lần) =====
                if not questDoneForZone[zKey] then
                    local npc = findQuestNPCNearZone(currentZone.center)
                    if npc then
                        interactNPC(npc)
                    end
                    questDoneForZone[zKey] = true
                end
                -- Bay đến trung tâm zone
                flyTo(charHRP, currentZone.center)
                Fluent:Notify({
                    Title = "Zone mới",
                    Content = "Level " .. getPlayerLevel() .. " → Zone " .. currentZone.count .. " quái",
                    Duration = 4
                })
            end
        end

        -- ===== BƯỚC 3: Farm quái trong zone =====
        if currentZone then
            if not isTargetAlive(currentTarget) then
                stopHover(); expandHitbox(false)
                currentTarget = getNearestEnemyInZone(currentZone.center)

                -- Hết quái trong zone → reset zone tìm lại
                if not currentTarget then
                    currentZone = nil
                    task.wait(1); continue
                end

                local tHRP = currentTarget:FindFirstChild("HumanoidRootPart")
                if tHRP then
                    flyTo(charHRP, tHRP.Position)
                    expandHitbox(true)
                    startHover()
                end
            end

            if isTargetAlive(currentTarget) then
                doAttack()
            else
                stopHover(); expandHitbox(false)
                currentTarget = nil
            end
        end

        task.wait(0.3)
    end

    stopHover(); expandHitbox(false)
       currentTarget = nil
            end
        end

        task.wait(0.3)
    end

    stopHover(); expandHitbox(false)
    currentTarget = nil; currentZone = nil
end

