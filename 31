local ToggleAuto = Tabs.Main:AddToggle("ToggleAuto", {
    Title = "Auto Farm Level",
    Description = "Bay cao 25 studs, khóa target đến khi chết",
    Default = false
})

ToggleAuto:OnChanged(function()
    autoFarm = Options.ToggleAuto.Value
    if autoFarm then
        if autoFarmThread then task.cancel(autoFarmThread) end
        currentTarget = nil
        autoFarmThread = task.spawn(autoFarmLoop)
    else
        if autoFarmThread then task.cancel(autoFarmThread) end
        currentTarget = nil
        local char = player.Character
        local h = char and char:FindFirstChildOfClass("Humanoid")
        if h then h:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end
end)

