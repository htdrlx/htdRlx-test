-- Mở rộng hitbox để đánh được từ độ cao 25
local function expandHitbox(enable)
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if enable then
        originalHRPSize = hrp.Size
        -- Size Y = FLY_HEIGHT + buffer để chắc chắn chạm kẻ địch bên dưới
        hrp.Size = Vector3.new(10, FLY_HEIGHT + 10, 10)
    else
        if originalHRPSize then
            hrp.Size = originalHRPSize
            originalHRPSize = nil
        end
    end
end

