-- ================== 3. HELPER ==================
local function isTargetAlive(model)
    if not model or not model.Parent then return false end
    local h = model:FindFirstChildOfClass("Humanoid")
    return h ~= nil and h.Health > 0
end

local function getNearestEnemy()
    local char = player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local nearest, minDist = nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= char then
            local h = obj:FindFirstChildOfClass("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if h and hrp and h.Health > 0 then
                local d = (root.Position - hrp.Position).Magnitude
                if d < minDist then minDist = d; nearest = obj end
            end
        end
    end
    return nearest
end

-- ================== 4. HOVER: Lơ lửng trên đầu target ==================
local function stopHover()
    if hoverConn then
        hoverConn:Disconnect()
        hoverConn = nil
    end
    -- Trả physics về bình thường
    local char = player.Character
    local h = char and char:FindFirstChildOfClass("Humanoid")
    if h then h:ChangeState(Enum.HumanoidStateType.GettingUp) end
    -- Trả cam về
    local cam = workspace.CurrentCamera
    if cam then cam.CameraType = Enum.CameraType.Custom end
end

local function startHover(targetHRP)
    stopHover() -- dọn cái cũ trước

    local char = player.Character
    if not char then return end
    local charHRP = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not charHRP or not humanoid then return end

    -- Tắt physics để không bị gravity kéo xuống
    humanoid:ChangeState(Enum.HumanoidStateType.Physics)

    hoverConn = RunService.Heartbeat:Connect(function()
        -- Nếu target chết hoặc farm tắt thì dừng hover
        if not autoFarm or not isTargetAlive(currentTarget) then
            stopHover()
            return
        end

        local char2 = player.Character
        local hrp2 = char2 and char2:FindFirstChild("HumanoidRootPart")
        local tHRP = currentTarget and currentTarget:FindFirstChild("HumanoidRootPart")
        if not hrp2 or not tHRP then stopHover() return end

        -- Giữ nhân vật lơ lửng tại Y = target.Y + FLY_HEIGHT
        local hoverY = tHRP.Position.Y + FLY_HEIGHT
        local lookPos = Vector3.new(tHRP.Position.X, hoverY, tHRP.Position.Z)

        -- Offset ra phía trước ATTACK_RANGE
        local dir = (hrp2.Position - tHRP.Position)
        dir = Vector3.new(dir.X, 0, dir.Z)
        local offset = dir.Magnitude > 0 and dir.Unit * ATTACK_RANGE or Vector3.new(0, 0, ATTACK_RANGE)

        hrp2.CFrame = CFrame.new(
            Vector3.new(tHRP.Position.X + offset.X, hoverY, tHRP.Position.Z + offset.Z),
            lookPos
        )
    end)
end

-- ================== 5. BAY (HEARTBEAT + TÁCH CAM) ==================
local function flyTo(charHRP, targetPos)
    local char = player.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    -- Tắt physics
    humanoid:ChangeState(Enum.HumanoidStateType.Physics)

    -- Tách cam: giữ yên tại vị trí hiện tại, nhân vật bay còn cam đứng im
    local cam = workspace.CurrentCamera
    cam.CameraType = Enum.CameraType.Scriptable
    local savedCamCF = cam.CFrame  -- lưu vị trí cam hiện tại

    -- Điểm đến cao hơn target FLY_HEIGHT
    local highPos = Vector3.new(targetPos.X, targetPos.Y + FLY_HEIGHT, targetPos.Z)
    local dir = Vector3.new(charHRP.Position.X - targetPos.X, 0, charHRP.Position.Z - targetPos.Z)
    local offset = dir.Magnitude > 0 and dir.Unit * ATTACK_RANGE or Vector3.new(0, 0, ATTACK_RANGE)
    local goalPos = highPos + offset
    local goalCF = CFrame.new(goalPos, Vector3.new(targetPos.X, goalPos.Y, targetPos.Z))

    local startCF = charHRP.CFrame
    local distance = (charHRP.Position - goalPos).Magnitude
    local totalTime = math.clamp(distance / TWEEN_SPEED, 0.05, 3)
    local elapsed = 0
    local done = false

    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not autoFarm then
            done = true; conn:Disconnect(); return
        end
        elapsed = elapsed + dt
        local alpha = math.clamp(elapsed / totalTime, 0, 1)

        -- Giật kiểu premium: snap theo bước 0.05
        local snappedAlpha = math.floor(alpha / 0.05) * 0.05
        charHRP.CFrame = startCF:Lerp(goalCF, snappedAlpha)

        -- Cam đứng yên trong lúc bay
        cam.CFrame = savedCamCF

        if alpha >= 1 then done = true; conn:Disconnect() end
    end)

    while not done do RunService.Heartbeat:Wait() end

    -- Trả cam về Custom sau khi bay xong
    cam.CameraType = Enum.CameraType.Custom
    task.wait(0.05)
end

-- ================== 6. ATTACK ==================
-- Tìm nút attack trong PlayerGui (nút đấm/fist ở dưới màn hình)
local attackButton = nil
local function findAttackButton()
    local gui = player:WaitForChild("PlayerGui")
    for _, obj in ipairs(gui:GetDescendants()) do
        if obj:IsA("ImageButton") or obj:IsA("TextButton") then
            local name = obj.Name:lower()
            if name:find("attack") or name:find("punch") or name:find("hit")
            or name:find("fight") or name:find("skill") or name:find("basic")
            or name:find("normal") or name:find("action") or name:find("tap") then
                return obj
            end
        end
    end
    return nil
end

local function doAttack()
    -- Thử dùng nút GUI trước
    if not attackButton or not attackButton.Parent then
        attackButton = findAttackButton()
    end

    if attackButton and attackButton.Parent then
        -- Fire thẳng event của nút, không cần chuột
        local ok1 = pcall(function() attackButton.MouseButton1Click:Fire() end)
        if not ok1 then
            pcall(function() attackButton.Activated:Fire() end)
        end
    else
        -- Fallback: click vào vị trí nút đấm ở dưới giữa màn hình
        local sz = workspace.CurrentCamera.ViewportSize
        local bx = math.floor(sz.X / 2)
        local by = math.floor(sz.Y * 0.85) -- nút đấm thường ở 85% chiều cao
        VirtualInputManager:SendMouseMoveEvent(-9999, -9999, game) -- đẩy cursor ra ngoài ngay sau
        VirtualInputManager:SendMouseButtonEvent(bx, by, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(bx, by, 0, false, game, 1)
        VirtualInputManager:SendMouseMoveEvent(-9999, -9999, game)
    end
end

-- ================== 7. MAIN LOOP ==================
local function autoFarmLoop()
    while autoFarm do
        local char = player.Character
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        if not (char and humanoid and humanoid.Health > 0) then
            stopHover()
            task.wait(0.5); continue
        end

        local charHRP = char:FindFirstChild("HumanoidRootPart")
        if not charHRP then task.wait(0.5); continue end

        -- Chỉ đổi target khi target cũ chết
        if not isTargetAlive(currentTarget) then
            stopHover()
            currentTarget = getNearestEnemy()

            -- Bay đến target mới
            if currentTarget then
                local tHRP = currentTarget:FindFirstChild("HumanoidRootPart")
                if tHRP then
                    flyTo(charHRP, tHRP.Position)
                    -- Bắt đầu hover lơ lửng trên đầu target
                    startHover(tHRP)
                end
            end
        end

        -- Target vẫn còn sống → đánh
        if isTargetAlive(currentTarget) then
            doAttack()
        else
            stopHover()
            currentTarget = nil
        end

        task.wait(0.3)
    end

    stopHover()
    currentTarget = nil
end

