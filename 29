-- ================== 3. AUTO FARM LEVEL ==================

-- FIX #5: Tìm kẻ địch theo đệ quy (tìm cả trong folder/model lồng nhau)
local function getNearestEnemy()
    local character = player.Character
    if not character then return nil end
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local nearest = nil
    local minDist = math.huge

    -- FIX #6: Dùng GetDescendants thay GetChildren để không bỏ sót model trong folder
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= character and obj ~= player.Character then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if humanoid and hrp and humanoid.Health > 0 then
                local dist = (root.Position - hrp.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = obj
                end
            end
        end
    end
    return nearest
end

local function autoFarmLoop()
    while autoFarm do
        -- FIX #7: Kiểm tra character còn sống không trước khi làm gì
        local character = player.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if character and humanoid and humanoid.Health > 0 then
            local target = getNearestEnemy()
            if target then
                local targetHRP = target:FindFirstChild("HumanoidRootPart")
                local charHRP = character:FindFirstChild("HumanoidRootPart")
                if targetHRP and charHRP then
                    local distance = (charHRP.Position - targetHRP.Position).Magnitude

                    -- FIX #8: Không cần tween nếu đã đứng gần
                    if distance > 5 then
                        local tweenTime = math.clamp(distance / TWEEN_SPEED, 0.05, 2)
                        local tweenInfo = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear)

                        -- FIX #9: Offset nhẹ để không tween vào đúng trong người kẻ địch
                        local targetCF = targetHRP.CFrame * CFrame.new(0, 0, 3)
                        local tween = TweenService:Create(charHRP, tweenInfo, {CFrame = targetCF})
                        tween:Play()
                        tween.Completed:Wait()
                    end

                    -- FIX #10: Click đúng vị trí trung tâm màn hình thay vì (0,0,0)
                    local cam = workspace.CurrentCamera
                    local screenSize = cam.ViewportSize
                    local cx = math.floor(screenSize.X / 2)
                    local cy = math.floor(screenSize.Y / 2)

                    VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
                    task.wait(0.05)
                    VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
                end
            end
        end
        task.wait(0.5)
    end
end

-- FIX #11: Toggle đúng cách - hủy thread cũ trước khi tạo mới
local ToggleAuto = Tabs.Main:AddToggle("ToggleAuto", {
    Title = "Auto Farm Level",
    Description = "Bay Tween 300 studs/s, tự đánh quái",
    Default = false
})

ToggleAuto:OnChanged(function()
    autoFarm = Options.ToggleAuto.Value
    if autoFarm then
        -- Hủy thread cũ nếu còn chạy
        if autoFarmThread then
            task.cancel(autoFarmThread)
            autoFarmThread = nil
        end
        autoFarmThread = task.spawn(autoFarmLoop)
    else
        if autoFarmThread then
            task.cancel(autoFarmThread)
            autoFarmThread = nil
        end
    end
end)

