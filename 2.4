LockIcon.BackgroundTransparency = 1
LockIcon.Image = "rbxassetid://237305954"
LockIcon.ImageColor3 = Color3.fromRGB(255, 255, 255)

-- ===== TẠO CROSSHAIR =====
local CrosshairColor = Color3.fromRGB(0, 255, 255)
local TargetGui = Instance.new("BillboardGui")
TargetGui.Name = "AimlockCrosshair"
TargetGui.AlwaysOnTop = true
TargetGui.Size = UDim2.new(5, 0, 5, 0)
TargetGui.LightInfluence = 0

local Container = Instance.new("Frame", TargetGui)
Container.Size = UDim2.new(1, 0, 1, 0)
Container.BackgroundTransparency = 1

local function makeScaleLine(wScale, hScale, pos, rot)
    local line = Instance.new("Frame", Container)
    line.BackgroundColor3 = CrosshairColor
    line.BorderSizePixel = 0
    line.Size = UDim2.new(wScale, 0, hScale, 0)
    line.Position = pos
    line.AnchorPoint = Vector2.new(0.5, 0.5)
    line.Rotation = rot
end

makeScaleLine(0.25, 0.03, UDim2.new(0.15, 0, 0.15, 0), -45) 
makeScaleLine(0.25, 0.03, UDim2.new(0.85, 0, 0.15, 0), 45)  
makeScaleLine(0.25, 0.03, UDim2.new(0.15, 0, 0.85, 0), 45)  
makeScaleLine(0.25, 0.03, UDim2.new(0.85, 0, 0.85, 0), -45) 

local dot = Instance.new("Frame", Container)
dot.BackgroundColor3 = CrosshairColor
