Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

-- ===== HÀM KIỂM TRA MỤC TIÊU (ĐÃ TỐI ƯU SIÊU MƯỢT) =====
local function getBestTarget()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end

    local root = char.HumanoidRootPart
    local bestTarget = nil
    local shortestDistance = math.huge
    local viewportCenter = Camera.ViewportSize / 2

    -- THAY ĐỔI LỚN NHẤT: Chỉ quét qua người chơi thay vì toàn map
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if CONFIG.TargetTeam and player.Team == LocalPlayer.Team then continue end

        local model = player.Character
        if model then
            local hum = model:FindFirstChildOfClass("Humanoid")
            local targetPart = model:FindFirstChild(CONFIG.AimPart) or model:FindFirstChild("HumanoidRootPart")
            
            if hum and hum.Health > 0 and targetPart and not model:FindFirstChildOfClass("ForceField") then
                local distToTarget = (root.Position - targetPart.Position).Magnitude
                if distToTarget <= CONFIG.MaxDistance then
                    
                    if not CONFIG.IgnoreWalls then
                        local rayParams = RaycastParams.new()
                        rayParams.FilterType = Enum.RaycastFilterType.Exclude
                        rayParams.FilterDescendantsInstances = {char, model}
                        
                        local rayResult = workspace:Raycast(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position).Unit * distToTarget, rayParams)
                        if rayResult then continue end 
                    end

                    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen then
                        local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - viewportCenter).Magnitude
                        if screenDist < shortestDistance then
                            shortestDistance = screenDist
                            bestTarget = model
                        end
                    end
                end
            end
        end
    end
    return bestTarget
end

-- ===== UPDATE UI =====
local function updateUI()
    if AimlockEnabled then
        if CurrentTarget then
            UIStroke.Color = CrosshairColor
            LockIcon.ImageColor3 = CrosshairColor
        else
            UIStroke.Color = Color3.fromRGB(255, 255, 50)
            LockIcon.ImageColor3 = Color3.fromRGB(255, 255, 50)
        end
    else
        UIStroke.Color = Color3.fromRGB(255, 255, 255)
        LockIcon.ImageColor3 = Color3.fromRGB(255, 255, 255)
        TargetGui.Parent = nil
    end
end

-- ===== VÒNG LẶP AIMLOCK (TỐI ƯU KHÔNG LỖI JITTER) =====
RunService.RenderStepped:Connect(function(dt)
    if not AimlockEnabled then return end

    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end

    local needNewTarget = false
    if not CurrentTarget or not CurrentTarget.Parent then
        needNewTarget = true
    else
        local hum = CurrentTarget:FindFirstChildOfClass("Humanoid")
        local part = CurrentTarget:FindFirstChild(CONFIG.AimPart) or CurrentTarget:FindFirstChild("HumanoidRootPart")
        if not hum or hum.Health <= 0 or not part then
            needNewTarget = true
        end
    end

    if needNewTarget then
        CurrentTarget = getBestTarget()
        updateUI()
    end

    if CurrentTarget then
        local targetPart = CurrentTarget:FindFirstChild(CONFIG.AimPart) or CurrentTarget:FindFirstChild("HumanoidRootPart")
        if targetPart then
            if TargetGui.Parent ~= targetPart then
                TargetGui.Parent = targetPart
            end

            -- Nội suy Camera mượt mà thay vì ép Scriptable
            local targetPos = targetPart.Position
            local camPos = Camera.CFrame.Position
            
            local newCFrame = CFrame.new(camPos, targetPos)

            if CONFIG.Smoothness >= 1 then
                Camera.CFrame = newCFrame
            else
                -- Delta time scaling (dt * 60) để tốc độ lock ổn định bất kể FPS là 30, 60 hay 144
                local lerpFactor = math.clamp(CONFIG.Smoothness * (dt * 60), 0.01, 1)
                Camera.CFrame = Camera.CFrame:Lerp(newCFrame, lerpFactor)
            end
        end
    end
end)

-- ===== TOGGLE AIMLOCK =====
local function toggleAimlock()
    AimlockEnabled = not AimlockEnabled
    if not AimlockEnabled then
        CurrentTarget = nil
    end
    updateUI()
end

ToggleButton.MouseButton1Click:Connect(toggleAimlock)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == CONFIG.LockKey then
        toggleAimlock()
    end
end) 
