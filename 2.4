-- ===== CẤU HÌNH (TÙY CHỈNH TẠI ĐÂY) =====
local CONFIG = {
    AimPart = "Head",               
    MaxDistance = 400,              
    LockKey = Enum.KeyCode.LeftControl, 
    IgnoreWalls = true,             
    TargetTeam = false,
    Smoothness = 0.5, -- GIÁ TRỊ MỚI: Từ 0.01 đến 1. Để 1 là dính chặt, < 1 là mượt dần.
}

-- ===== KHỞI TẠO TÀI NGUYÊN =====
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local AimlockEnabled = false
local CurrentTarget = nil

-- ===== TẠO GIAO DIỆN NÚT BẬT/TẮT =====
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "HTDrobloxAimlockPro_HitboxMode"
ScreenGui.ResetOnSpawn = false

