-- ================== 3. AUTO FARM LEVEL (TWEEN SPEED 300) ==================
local function getNearestEnemy()
    local character = player.Character
    if not character then return nil end
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local nearest = nil
    local minDist = math.huge
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj ~= character then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if humanoid and hrp and humanoid.Health > 0 then
                local dist = (root.Position - hrp.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = obj
                end
            end
        end
    end
    return nearest
end

local function autoFarmLoop()
    while autoFarm do
        local character = player.Character
        if character then
            local target = getNearestEnemy()
            if target then
                local targetHRP = target:FindFirstChild("HumanoidRootPart")
                local charHRP = character:FindFirstChild("HumanoidRootPart")
                if targetHRP and charHRP then
                    local distance = (charHRP.Position - targetHRP.Position).Magnitude
                    local tweenTime = distance / TWEEN_SPEED
                    tweenTime = math.clamp(tweenTime, 0.1, 2) -- Giới hạn thời gian
                    
                    local tweenInfo = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear)
                    local tween = TweenService:Create(charHRP, tweenInfo, {CFrame = targetHRP.CFrame})
                    tween:Play()
                    tween.Completed:Wait()

                    -- Tấn công
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                    task.wait(0.05)
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                end
            end
        end
        task.wait(0.5) -- Nghỉ giữa các lần quét
    end
end

-- Toggle Auto Farm (Đã sửa lỗi Callback)
