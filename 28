-- Bo tròn + viền
Instance.new("UICorner", ToggleButton).CornerRadius = UDim.new(0.5, 0)
local stroke = Instance.new("UIStroke", ToggleButton)
stroke.Color = Color3.fromRGB(70, 70, 70)
stroke.Thickness = 1.5

-- Kéo thả
local dragging, dragInput, dragStart, startPos = false
local isClicking = false

local function updateDrag(input)
    local delta = input.Position - dragStart
    ToggleButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

ToggleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        isClicking = true
        dragStart = input.Position
        startPos = ToggleButton.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

ToggleButton.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        if (input.Position - dragStart).Magnitude > 5 then
            isClicking = false
        end
        updateDrag(input)
    end
end)

-- Hiệu ứng tap (Tween)
local function playTapAnimation()
    local tween = TweenService:Create(ToggleButton, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 50, 0, 50)})
    tween:Play()
    tween.Completed:Wait()
    TweenService:Create(ToggleButton, TweenInfo.new(0.1), {Size = UDim2.new(0, 45, 0, 45)}):Play()
end

-- Camera detach
local function setCameraDetach(enable)
    local cam = workspace.CurrentCamera
    if enable then
        cam.CameraType = Enum.CameraType.Scriptable
    else
        cam.CameraType = Enum.CameraType.Custom
    end
    cameraDetached = enable
end

-- Xử lý khi tap (bật/tắt menu)
ToggleButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if isClicking then
            playTapAnimation()
            menuOpen = not menuOpen
            setCameraDetach(menuOpen)
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftControl, false, game)
            task.wait()
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
        end
    end
end)

